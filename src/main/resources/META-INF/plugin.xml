<idea-plugin>
    <id>org.intellij.sdk.lore</id>
    <name>Lore</name>
    <vendor url="https://fleetinglore.github.io">FleetingLore</vendor>
    <description><![CDATA[
        Lore support for IntellIJ
        Implementation: Web Collections
    ]]></description>
    <depends>com.intellij.modules.lsp</depends>
    <extensions defaultExtensionNs="com.intellij">
        <fileType name="Lore File" implementationClass="org.intellij.sdk.lore.LoreFileType" fieldName="INSTANCE"
                  language="Lore" extensions="lore"/>
    </extensions>
</idea-plugin>